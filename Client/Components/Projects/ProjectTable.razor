@using Core
@inject NavigationManager Nav

<div class="table-wrap">
    <table class="proj-table">
        <thead>
            <tr>
                <th class="col-project">Projekt</th>
                <th class="col-date">Oprettet</th>
                <th class="col-actions">Handling</th>
            </tr>
        </thead>
        <tbody>
            @if (Projects != null)
            {
                @foreach (var p in Projects)
                {
                    <tr>
                        <td>
                            <div class="project-cell">
                                <div class="thumb">
                                    <span class="thumb-fallback">@Initial(p.Name)</span>
                                    @if (!string.IsNullOrWhiteSpace(p.ImageUrl))
                                    {
                                        @* Billedet ligger oven på fallback-bogstavet. Hvis billedet ikke kan
                                           hentes (tomt, 404 eller blokeret), skjules det, og bogstavet vises. *@
                                        <img src="@p.ImageUrl" alt="@p.Name"
                                             onerror="this.onerror=null;this.style.display='none'" />
                                    }
                                </div>
                                <span class="project-name">@p.Name</span>
                            </div>
                        </td>
                        <td class="date-cell">@p.DateCreated.ToString("dd/MM/yyyy")</td>
                        <td>
                            <div class="actions-cell">
                                <button class="btn-details" @onclick="() => GotoDetails(p.ProjectId)">Se detaljer</button>

                                <div class="menu-wrap">
                                    <button class="dots-btn" @onclick="() => ToggleMenu(p.ProjectId)" @onfocusout="CloseMenuDelayed" aria-label="Flere handlinger">
                                        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="bi bi-three-dots-vertical" viewBox="0 0 16 16">
                                            <path d="M9.5 13a1.5 1.5 0 1 1-3 0 1.5 1.5 0 0 1 3 0m0-5a1.5 1.5 0 1 1-3 0 1.5 1.5 0 0 1 3 0m0-5a1.5 1.5 0 1 1-3 0 1.5 1.5 0 0 1 3 0"/>
                                        </svg>
                                    </button>

                                    @if (_openMenuId == p.ProjectId)
                                    {
                                        <div class="dropdown">
                                            <button class="dropdown-item" @onclick="() => GotoEdit(p.ProjectId)">Rediger</button>
                                            <button class="dropdown-item danger" @onclick="() => Delete(p.ProjectId)">Slet projekt</button>
                                        </div>
                                    }
                                </div>
                            </div>
                        </td>
                    </tr>
                }
            }
        </tbody>
    </table>
</div>

@code {
    [Parameter] public IEnumerable<Project>? Projects { get; set; }
    [Parameter] public EventCallback<int> OnDelete { get; set; }

    private int? _openMenuId;

    private void ToggleMenu(int id) => _openMenuId = _openMenuId == id ? (int?)null : id;

    private async Task CloseMenuDelayed()
    {
        await Task.Delay(200); // giv klik på menupunkterne tid til at registrere
        _openMenuId = null;
    }

    private void GotoDetails(int id) => Nav.NavigateTo($"project/{id}");
    private void GotoEdit(int id) => Nav.NavigateTo($"project/edit/{id}");

    private async Task Delete(int id)
    {
        _openMenuId = null;
        if (OnDelete.HasDelegate) await OnDelete.InvokeAsync(id);
    }

    // Første bogstav i projektnavnet — bruges som pæn fallback når der ikke er et billede.
    private static string Initial(string? name) =>
        string.IsNullOrWhiteSpace(name) ? "?" : name.Trim()[..1].ToUpper();
}
