<div class="page">
    <div class="sidebar">
        <NavMenu />
    </div>

    <main>
        @* The top row for Logout can be hidden or moved to the NavMenu for mobile *@
        <article class="content px-4">
            @Body
        </article>
    </main>
</div>

@code {
    private async Task Logout()
    { 
        await LocalStorage.RemoveItemAsync("user");
        navManager.NavigateTo("/", true);
    }
}