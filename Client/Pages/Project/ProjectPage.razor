@page "/"
@using Client.Components.Projects
@using Core
@using Client.Service
@inject HttpClient Http
@inject NavigationManager Nav
@inject Blazored.LocalStorage.ILocalStorageService LocalStorage

<div class="admin-container">
    <div class="header-section">
        <h3>Alle projekter</h3>

        <div class="view-toggle" role="group" aria-label="Visning">
            <button class="toggle-btn @(_tableView ? "" : "active")" @onclick="() => SetView(false)">
                <i class="bi bi-grid-3x3-gap-fill"></i> Kort
            </button>
            <button class="toggle-btn @(_tableView ? "active" : "")" @onclick="() => SetView(true)">
                <i class="bi bi-list-ul"></i> Tabel
            </button>
        </div>
    </div>

    @if (_projects == null)
    {
        <div class="loading-state full-screen-center">
            <div class="spinner-border text-primary" role="status"></div>
            <p>Indlæser projekter...</p>
        </div>
    }
    else if (!_projects.Any())
    {
        <div class="empty-state">
            <p>Ingen projekter fundet.</p>
        </div>
    }
    else if (_tableView)
    {
        <ProjectTable Projects="_projects" OnDelete="DeleteProject" />
    }
    else
    {
        <ProjectGrid Projects="_projects" OnDelete="DeleteProject" />
    }
</div>


@code {
    private List<Project>? _projects;
    private bool _tableView; // false = kort (standard), true = tabel

    protected override async Task OnInitializedAsync()
    {
        // Husk brugerens valgte visning på tværs af besøg
        try { _tableView = await LocalStorage.GetItemAsync<bool>("projectView_table"); }
        catch { /* ignorér — falder tilbage til kort-visning */ }

        try
        {
            _projects = await Http.GetFromJsonAsync<List<Project>>("api/project");
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Fejl: {ex.Message}");
        }
    }

    private async Task SetView(bool tableView)
    {
        _tableView = tableView;
        await LocalStorage.SetItemAsync("projectView_table", tableView);
    }

    // Slet projekt
    private async Task DeleteProject(int id)
    {
        var response = await Http.DeleteAsync($"{Server.Url}/api/project/{id}");

        if (response.IsSuccessStatusCode)
        {
            _projects = await Http.GetFromJsonAsync<List<Project>>("api/project");
        }
    }
}
